# Formspree endpoint for contact form submissions
# Get one at https://formspree.io — replace with your form ID
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Calendly booking URL (optional)
# Add once your Calendly link is live
VITE_CALENDLY_URL=https://calendly.com/YOUR_USERNAME/consultation

# Umami analytics (optional)
# Set up at https://umami.is or self-host
VITE_ANALYTICS_ENDPOINT=https://your-umami-instance.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id
